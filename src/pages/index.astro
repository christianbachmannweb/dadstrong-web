---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav__inner">
      <span class="nav__logo">DAD STRONG</span>
      <a href="#download" class="nav__cta">Download</a>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════════════════ HERO -->
  <section class="hero">

    <div class="hero__bars" aria-hidden="true">
      <!-- Block 1 -->
      <div class="hbar" style="--h:28%;--delay:.05s"></div>
      <div class="hbar" style="--h:31%;--delay:.1s"></div>
      <div class="hbar" style="--h:34%;--delay:.15s"></div>
      <div class="hbar hbar--mark" style="--h:37%;--delay:.2s" data-label="60 kg"></div>
      <div class="hbar hbar--gap"></div>
      <!-- Block 2 -->
      <div class="hbar" style="--h:43%;--delay:.25s"></div>
      <div class="hbar" style="--h:47%;--delay:.3s"></div>
      <div class="hbar" style="--h:51%;--delay:.35s"></div>
      <div class="hbar hbar--mark" style="--h:55%;--delay:.4s" data-label="80 kg"></div>
      <div class="hbar hbar--gap"></div>
      <!-- Block 3 -->
      <div class="hbar" style="--h:61%;--delay:.45s"></div>
      <div class="hbar" style="--h:66%;--delay:.5s"></div>
      <div class="hbar" style="--h:72%;--delay:.55s"></div>
      <div class="hbar hbar--mark" style="--h:77%;--delay:.6s" data-label="90 kg"></div>
      <div class="hbar hbar--gap"></div>
      <!-- Block 4 – peak -->
      <div class="hbar" style="--h:82%;--delay:.65s"></div>
      <div class="hbar" style="--h:87%;--delay:.7s"></div>
      <div class="hbar" style="--h:92%;--delay:.75s"></div>
      <div class="hbar hbar--peak hbar--mark" style="--h:100%;--delay:.8s" data-label="100 kg"></div>
    </div>

    <div class="container">
      <p class="label label--accent hero__label">FÜR VÄTER · TRAINING · iOS</p>
      <h1 class="hero__title">DAD<br>STRONG</h1>
      <div class="hero__sub">
        <p class="hero__tagline">Zwei Einheiten.<br>Echter Fortschritt.</p>
        <p class="hero__body">Als Papa hast du keine Zeit für Trainings-Chaos.<br>Dad Strong gibt dir einen fixen Plan — und sonst nichts.</p>
        <a href="#download" class="btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          App Store
        </a>
      </div>
    </div>
    <div class="hero__divider" aria-hidden="true"></div>
  </section>

  <!-- ═══════════════════════════════════════════════ KENNST DU DAS? -->
  <section class="section section--surface" id="problem">
    <div class="container">
      <div class="section__header">
        <p class="label label--muted">DAS PAPA-PROBLEM</p>
        <h2 class="section__title">Kennst du das?</h2>
      </div>
      <div class="pain__grid">
        <div class="pain reveal">
          <span class="pain__num">—</span>
          <p class="pain__text">Zu viele Übungen zur Auswahl. Du weißt nicht, womit du anfangen sollst.</p>
        </div>
        <div class="pain reveal" style="--delay:.08s">
          <span class="pain__num">—</span>
          <p class="pain__text">Du startest motiviert — und hörst nach zwei Wochen wieder auf.</p>
        </div>
        <div class="pain reveal" style="--delay:.16s">
          <span class="pain__num">—</span>
          <p class="pain__text">Du trainierst, aber siehst keine echten Ergebnisse. Irgendwas stimmt nicht.</p>
        </div>
        <div class="pain reveal" style="--delay:.24s">
          <span class="pain__num">—</span>
          <p class="pain__text">Dein Alltag lässt gerade keinen komplexen Trainingsplan zu. Arbeit, Kinder, alles auf einmal.</p>
        </div>
        <div class="pain reveal" style="--delay:.32s">
          <span class="pain__num">—</span>
          <p class="pain__text">Du vergleichst dich mit Influencern, die keinen Vollzeitjob haben. Und fühlst dich schlecht dabei.</p>
        </div>
        <div class="pain reveal" style="--delay:.4s">
          <span class="pain__num">—</span>
          <p class="pain__text">Du weißt, dass du eigentlich fit sein willst — aber der Kopf ist schon den ganzen Tag woanders.</p>
        </div>
      </div>
      <div class="pain__answer reveal" style="--delay:.5s">
        <p class="pain__answer-text">Dann ist Dad Strong für dich.</p>
        <p class="pain__answer-sub">Kein System das dich überfordert. Kein Druck. Nur ein Plan, den du trotz echtem Leben durchziehen kannst.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════ DIE PHILOSOPHIE -->
  <section class="section" id="philosophy">
    <div class="container">
      <div class="section__header">
        <p class="label label--accent">DIE PHILOSOPHIE</p>
        <h2 class="section__title">Warum genau<br>dieser Trainingsplan?</h2>
        <p class="section__lead">Dad Strong basiert auf wenigen, gut gestützten Prinzipien — nicht auf dem neuesten Trend.</p>
      </div>

      <div class="philosophy__layout">
        <div class="philosophy__cards">
          <article class="card reveal">
            <span class="card__num">01</span>
            <h3 class="card__title">Wenige Übungen</h3>
            <p class="card__body">Mehr Fokus. Weniger Chaos. Grundübungen trainieren viele Muskelgruppen gleichzeitig — maximaler Nutzen pro investierter Papa-Zeit.</p>
          </article>
          <article class="card reveal" style="--delay:.08s">
            <span class="card__num">02</span>
            <h3 class="card__title">Fokus auf Beine & hintere Kette</h3>
            <p class="card__body">Kraft. Stabilität. Energie für den Alltag. Deshalb liegt hier bewusst der Schwerpunkt — das zahlt sich auch auf dem Spielplatz aus.</p>
          </article>
          <article class="card reveal" style="--delay:.16s">
            <span class="card__num">03</span>
            <h3 class="card__title">Progression statt Zerstörung</h3>
            <p class="card__body">Wenige harte Arbeitssätze, klare Steigerung, messbare Entwicklung. Kein Muskelkater der dich am nächsten Tag lahmlegt.</p>
          </article>
          <article class="card reveal" style="--delay:.24s">
            <span class="card__num">04</span>
            <h3 class="card__title">Entwickelt für Väter</h3>
            <p class="card__body">Arbeit. Familie. Verpflichtungen. Dad Strong läuft in kurzen Einheiten, braucht wenig Nachdenken — und lässt sich trotzdem konsequent durchziehen.</p>
          </article>
        </div>

        <div class="philosophy__mockup reveal" style="--delay:.1s">
          <div class="iphone">
            <div class="iphone__dynamic-island" aria-hidden="true"></div>
            <div class="iphone__btn iphone__btn--action" aria-hidden="true"></div>
            <div class="iphone__btn iphone__btn--vol-up" aria-hidden="true"></div>
            <div class="iphone__btn iphone__btn--vol-down" aria-hidden="true"></div>
            <div class="iphone__btn iphone__btn--side" aria-hidden="true"></div>
            <div class="iphone__screen">
              <img
                src="/screenshots/dadstrong-app-home-screen.png"
                alt="Dad Strong App – Home Screen"
                width="390"
                height="844"
                loading="lazy"
              />
            </div>
          </div>
          <div class="mockup__label">
            <span class="label label--muted" style="margin:0">STARTSCREEN</span>
            <p class="mockup__caption">Dein Training. Sofort sichtbar.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════ DIE GESCHICHTE -->
  <section class="section about-section" id="story">
    <div class="container">
      <div class="about__layout">
        <div class="about__left">
          <p class="label label--muted">WARUM DAD STRONG?</p>
          <blockquote class="about__pull">
            "Ich habe Training jahrelang falsch betrachtet."
          </blockquote>
          <p class="about__byline">— Christian Bachmann, Entwickler</p>
        </div>
        <div class="about__right reveal">
          <p>Ich dachte: mehr ist besser. Härter ist besser. Erschöpfter ist besser.</p>
          <p>Ich habe versucht, Trainingspläne von Menschen nachzuleben, deren Alltag nichts mit meinem zu tun hatte. Menschen ohne Vollzeitjob, Schlafmangel, Kinder, Verantwortung.</p>
          <p>Und jedes Mal hatte ich das Gefühl: nicht diszipliniert genug zu sein.</p>

          <div class="about__rule"></div>

          <p>Mein eigentliches Problem war nicht Motivation. Es war: zu hohe Erwartungen, zu komplizierte Systeme, die Idee perfekt trainieren zu müssen.</p>
          <p>Der Kreislauf war immer gleich: maximal motiviert starten → zu viel wollen → ausbrennen → neu anfangen.</p>

          <div class="about__rule"></div>

          <p>Irgendwann wurde mir klar: Ich brauche kein perfektes Programm. Ich brauche ein System, das auch in ein echtes Leben passt — mit wenig Schlaf, wenig Zeit, viel Verantwortung.</p>
          <p class="about__conclusion">Dad Strong entstand nicht aus einer Business-Idee. Sondern aus echten Problemen. Genau das macht es glaubwürdig.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════ DER PLAN -->
  <section class="section section--surface" id="plan">
    <div class="container">
      <div class="section__header">
        <p class="label label--accent">DER PLAN</p>
        <h2 class="section__title">Training A & B</h2>
        <p class="section__lead">Fest. Nicht konfigurierbar. Das ist das Produkt.</p>
      </div>

      <div class="training__grid">
        <div class="training__block reveal">
          <header class="training__header">
            <span class="training__tag">Training A</span>
          </header>
          <div class="training__exercises">
            <div class="exercise">
              <div class="exercise__name">Kniebeuge</div>
              <div class="exercise__why">Hoher Gesamtreiz · Beine · Rumpf · Kraftaufbau</div>
            </div>
            <div class="exercise">
              <div class="exercise__name">Bankdrücken</div>
              <div class="exercise__why">Oberkörperkraft · progressiv belastbar · effizient</div>
            </div>
            <div class="exercise">
              <div class="exercise__name">Rudern</div>
              <div class="exercise__why">Rücken · Ausgleich zum Drücken · Haltung</div>
            </div>
            <div class="exercise">
              <div class="exercise__name">Bulgarian Split Squat</div>
              <div class="exercise__why">Unilateral · Beine · Balance · Beweglichkeit</div>
            </div>
            <div class="exercise">
              <div class="exercise__name">Farmer Walk</div>
              <div class="exercise__why">Grip · Rumpf · Kondition · mentale Stärke</div>
            </div>
          </div>
        </div>

        <div class="training__block reveal" style="--delay:.15s">
          <header class="training__header">
            <span class="training__tag">Training B</span>
          </header>
          <div class="training__exercises">
            <div class="exercise">
              <div class="exercise__name">Kreuzheben</div>
              <div class="exercise__why">Hintere Kette · Rücken · maximale Last · Fundament</div>
            </div>
            <div class="exercise">
              <div class="exercise__name">Overhead Press</div>
              <div class="exercise__why">Schultern · Rumpf · Stabilität · echte Kraft</div>
            </div>
            <div class="exercise">
              <div class="exercise__name">Klimmzüge</div>
              <div class="exercise__why">Rückenbreite · relative Kraft · Körpergewicht</div>
            </div>
            <div class="exercise">
              <div class="exercise__name">Frontkniebeuge</div>
              <div class="exercise__why">Beinvorderseite · aufrechte Haltung · Mobilität</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Warum nicht veränderbar -->
      <div class="training__why reveal" style="--delay:.2s">
        <div class="training__why-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
        </div>
        <div>
          <p class="training__why-title">Warum kann ich den Plan nicht anpassen?</p>
          <p class="training__why-body">Weil Variation den Fortschritt hindert. Wer die Übungen ständig wechselt, trainiert nie lange genug an einer Bewegung um wirklich stark zu werden. Lineare Progression braucht Kontinuität — keine Abwechslung. Der Plan ist das Produkt.</p>
        </div>
      </div>

      <!-- Progression Demo -->
      <div class="progression reveal" style="--delay:.25s">
        <div class="progression__header">
          <p class="label label--muted">LINEARE PROGRESSION · BEISPIEL KNIEBEUGE</p>
        </div>
        <div class="progression__track">
          <div class="progression__weeks">
            <span>Woche 1</span>
            <span>Woche 4</span>
            <span>Woche 8</span>
            <span>Woche 12</span>
          </div>
          <div class="progression__bar">
            <div class="progression__fill" id="progFill"></div>
          </div>
          <div class="progression__weights">
            <span class="prog-w">60 kg</span>
            <span class="prog-w">72 kg</span>
            <span class="prog-w">85 kg</span>
            <span class="prog-w prog-w--accent">100 kg</span>
          </div>
        </div>
        <p class="progression__note">Nicht garantiert — aber realistisch.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════ DIE APP -->
  <section class="section" id="app">
    <div class="container">
      <div class="section__header">
        <p class="label label--accent">DIE APP</p>
        <h2 class="section__title">Dein Training.<br>Deine Zahlen.</h2>
        <p class="section__lead">Entwickelt für Väter, die keine Zeit haben — aber trotzdem Ergebnisse wollen.</p>
      </div>
      <div class="features">

        <div class="feature reveal">
          <div class="feature__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </div>
          <div>
            <h3 class="feature__title">Workout-Tracking</h3>
            <p class="feature__body">Sets, Reps, Gewicht. Nach jedem Block bekommst du einen klaren Progressionsvorschlag — einfach bestätigen und steigern.</p>
          </div>
        </div>

        <div class="feature feature--accent reveal" style="--delay:.08s">
          <div class="feature__icon feature__icon--accent">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><circle cx="8" cy="15" r="1" fill="currentColor"/><circle cx="12" cy="15" r="1" fill="currentColor"/><circle cx="16" cy="15" r="1" fill="currentColor"/>
            </svg>
          </div>
          <div>
            <h3 class="feature__title">So funktioniert dein Streak</h3>
            <p class="feature__body">Jedes abgeschlossene Training zählt als ein Tag. Der Wochen-Kalender zeigt schwarz auf weiß: warst du dabei oder nicht. Kein Punkte-System, keine künstliche Gamification — nur deine echten Trainingstage. Das reicht.</p>
            <div class="streak__demo" aria-hidden="true">
              <span class="streak__day streak__day--done">Mo</span>
              <span class="streak__day streak__day--done">Di</span>
              <span class="streak__day streak__day--skip">Mi</span>
              <span class="streak__day streak__day--done">Do</span>
              <span class="streak__day streak__day--skip">Fr</span>
              <span class="streak__day streak__day--rest">Sa</span>
              <span class="streak__day streak__day--rest">So</span>
            </div>
          </div>
        </div>

        <div class="feature reveal" style="--delay:.16s">
          <div class="feature__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
          <div>
            <h3 class="feature__title">Körper-Dokumentation</h3>
            <p class="feature__body">Gewicht, Maße, Fotos — Front, Back, Side. Du siehst wo du gestartet bist und wohin die Reise geht.</p>
          </div>
        </div>

        <div class="feature reveal" style="--delay:.24s">
          <div class="feature__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
            </svg>
          </div>
          <div>
            <h3 class="feature__title">Zone 2 & Sprint</h3>
            <p class="feature__body">Ausdauer und Kondition — als Ergänzung zum Krafttraining. Herzfrequenz direkt via HealthKit.</p>
          </div>
        </div>

        <div class="feature reveal" style="--delay:.32s">
          <div class="feature__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
            </svg>
          </div>
          <div>
            <h3 class="feature__title">Home Screen Widget</h3>
            <p class="feature__body">Streak, letzte Sessions, nächstes Training — direkt auf dem Home Screen. Morgens aufmachen und sofort wissen: dran oder nicht.</p>
          </div>
        </div>

        <div class="feature reveal" style="--delay:.4s">
          <div class="feature__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>
            </svg>
          </div>
          <div>
            <h3 class="feature__title">Kein Account. Kein Abo.</h3>
            <p class="feature__body">Alles lokal auf deinem iPhone. iCloud Backup inklusive. Einmal kaufen — für immer nutzen.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ FAQ -->
  <section class="section section--surface" id="faq">
    <div class="container">
      <div class="section__header">
        <p class="label label--muted">FAQ</p>
        <h2 class="section__title">Häufige Fragen</h2>
      </div>
      <div class="faq__list">

        <details class="faq reveal">
          <summary class="faq__q">Kostet die App Geld?</summary>
          <p class="faq__a">Ja — einmaliger Kauf. Kein Abo, keine monatlichen Kosten, keine Premium-Version. Du bezahlst einmal und hast die App für immer.</p>
        </details>

        <details class="faq reveal" style="--delay:.06s">
          <summary class="faq__q">Gibt es ein Abo oder versteckte Kosten?</summary>
          <p class="faq__a">Nein. Keine Abonnements, keine In-App-Käufe, keine Werbung. Das war von Anfang an so geplant — weil du als Vater ohnehin genug Fixkosten hast.</p>
        </details>

        <details class="faq reveal" style="--delay:.12s">
          <summary class="faq__q">Kann ich meinen Trainingsplan anpassen?</summary>
          <p class="faq__a">Nein — und das ist Absicht. Variation hindert Fortschritt. Wer die Übungen ständig wechselt, baut keine echte Stärke auf. Der Plan ist das Produkt. Das ist der Punkt.</p>
        </details>

        <details class="faq reveal" style="--delay:.18s">
          <summary class="faq__q">Ist das wissenschaftlich fundiert?</summary>
          <p class="faq__a">Dad Strong basiert auf progressiver Überladung und Grundübungen — die Basis jedes seriösen Krafttrainingsprogramms. Keine Geheimformel, kein Trend. Nur das, was nachweislich funktioniert.</p>
        </details>

        <details class="faq reveal" style="--delay:.24s">
          <summary class="faq__q">Brauche ich ein Gym oder bestimmte Geräte?</summary>
          <p class="faq__a">Du brauchst eine Langhantel, Gewichte und eine Bank. Ein normales Gym reicht vollkommen. Kein Hightech-Equipment, kein teures Abo.</p>
        </details>

        <details class="faq reveal" style="--delay:.3s">
          <summary class="faq__q">Was wenn ich mal ein Training verpasse?</summary>
          <p class="faq__a">Dann machst du das nächste Training. Fertig. Dad Strong hat keinen künstlichen Streak-Druck. Leben passiert — das System ist dafür gebaut.</p>
        </details>

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════ CTA -->
  <section class="section cta-section" id="download">
    <div class="container">
      <div class="cta__inner reveal">
        <p class="label label--muted">AB SOFORT VERFÜGBAR</p>
        <blockquote class="cta__quote">
          Dad Strong reduziert Training auf das, was langfristig wirklich zählt.
        </blockquote>
        <a href="#" class="btn-primary btn-primary--large">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
