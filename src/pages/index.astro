---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import appHome from '../assets/images/dadstrong-app-home-screen.png';
import appMockupJourney from '../assets/images/app-mockup-journey.png';
import appMockupWarmup from '../assets/images/app-mockup-warmup.png';
import appMockupWidget from '../assets/images/app-mockup-widget.png';
import appMockupPause from '../assets/images/app-mockup-pause.png';
import appMockupZone2 from '../assets/images/iPhone-16-Pro-Max-zone-2.png';
import appMockupSprint from '../assets/images/iphone-16-sprint.png';
---

<Layout>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav__inner">
      <span class="nav__logo">DAD STRONG</span>
      <a href="#download" class="nav__cta">Download</a>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════════════════ HERO -->
  <section class="hero">

    <div class="hero__bars" aria-hidden="true">
      <!-- Block 1 -->
      <div class="hbar" style="--h:28%;--delay:.05s"></div>
      <div class="hbar" style="--h:31%;--delay:.1s"></div>
      <div class="hbar" style="--h:34%;--delay:.15s"></div>
      <div class="hbar hbar--mark" style="--h:37%;--delay:.2s" data-label="60 kg"></div>
      <div class="hbar hbar--gap"></div>
      <!-- Block 2 -->
      <div class="hbar" style="--h:43%;--delay:.25s"></div>
      <div class="hbar" style="--h:47%;--delay:.3s"></div>
      <div class="hbar" style="--h:51%;--delay:.35s"></div>
      <div class="hbar hbar--mark" style="--h:55%;--delay:.4s" data-label="80 kg"></div>
      <div class="hbar hbar--gap"></div>
      <!-- Block 3 -->
      <div class="hbar" style="--h:61%;--delay:.45s"></div>
      <div class="hbar" style="--h:66%;--delay:.5s"></div>
      <div class="hbar" style="--h:72%;--delay:.55s"></div>
      <div class="hbar hbar--mark" style="--h:77%;--delay:.6s" data-label="90 kg"></div>
      <div class="hbar hbar--gap"></div>
      <!-- Block 4 – peak -->
      <div class="hbar" style="--h:82%;--delay:.65s"></div>
      <div class="hbar" style="--h:87%;--delay:.7s"></div>
      <div class="hbar" style="--h:92%;--delay:.75s"></div>
      <div class="hbar hbar--peak hbar--mark" style="--h:100%;--delay:.8s" data-label="100 kg"></div>
    </div>

    <div class="container">
      <p class="label label--accent hero__label">FÜR VÄTER · TRAINING · iOS</p>
      <h1 class="hero__title">DAD<br>STRONG</h1>
      <div class="hero__sub">
        <p class="hero__tagline">Zwei Einheiten.<br>Echter Fortschritt.</p>
        <p class="hero__body">Für Papas die wenig Zeit haben, stark sein<br>und nackt gut aussehen wollen.</p>
        <a href="#download" class="btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          App Store
        </a>
      </div>
    </div>
    <div class="hero__divider" aria-hidden="true"></div>
  </section>

  <!-- ═══════════════════════════════════════════════ KENNST DU DAS? -->
  <section class="section section--surface" id="problem">
    <div class="container">
      <div class="section__header">
        <p class="label label--muted">DAS PAPA-PROBLEM</p>
        <h2 class="section__title">Kennst du das?</h2>
      </div>
      <div class="pain__grid">
        <div class="pain reveal">
          <span class="pain__num">—</span>
          <p class="pain__text">Zu viele Übungen zur Auswahl. Du weißt nicht, womit du anfangen sollst.</p>
        </div>
        <div class="pain reveal" style="--delay:.08s">
          <span class="pain__num">—</span>
          <p class="pain__text">Du startest motiviert — und hörst nach zwei Wochen wieder auf.</p>
        </div>
        <div class="pain reveal" style="--delay:.16s">
          <span class="pain__num">—</span>
          <p class="pain__text">Du trainierst, aber siehst keine echten Ergebnisse. Irgendwas stimmt nicht.</p>
        </div>
        <div class="pain reveal" style="--delay:.24s">
          <span class="pain__num">—</span>
          <p class="pain__text">Dein Alltag lässt gerade keinen komplexen Trainingsplan zu. Arbeit, Kinder, alles auf einmal.</p>
        </div>
        <div class="pain reveal" style="--delay:.32s">
          <span class="pain__num">—</span>
          <p class="pain__text">Du vergleichst dich mit Influencern, die keinen Vollzeitjob haben, keine Kinder, Anfang 20 sind — und täglich zwei Stunden Zeit für Training haben. Das ist nicht dein Leben.</p>
        </div>
        <div class="pain reveal" style="--delay:.4s">
          <span class="pain__num">—</span>
          <p class="pain__text">Du willst trainieren — aber irgendwie sabotierst du dich selbst. Kein Drama, keine Ausrede. Es passiert einfach. Immer wieder.</p>
        </div>
        <div class="pain reveal" style="--delay:.48s">
          <span class="pain__num">—</span>
          <p class="pain__text">Du denkst, du müsstest täglich trainieren. Schaffst es nicht. Also gar nichts.</p>
        </div>
        <div class="pain reveal" style="--delay:.56s">
          <span class="pain__num">—</span>
          <p class="pain__text">Du machst 15-Minuten-Workouts täglich — und fragst dich, warum sich nach Monaten nichts verändert hat.</p>
        </div>
        <div class="pain reveal" style="--delay:.64s">
          <span class="pain__num">—</span>
          <p class="pain__text">Du weißt eigentlich was du tun müsstest. Du suchst trotzdem noch den perfekten Plan. Und fängst deshalb nie wirklich an.</p>
        </div>
      </div>
      <div class="pain__answer reveal" style="--delay:.65s">
        <p class="pain__answer-text">Dann ist Dad Strong für dich.</p>
        <p class="pain__answer-sub">Für Papas die wenig Zeit haben, stark sein und nackt gut aussehen wollen. Du musst nicht täglich trainieren — zwei echte Einheiten pro Woche reichen. Und zwar wirklich.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ DIE REALITÄT -->
  <section class="section reality-section">
    <div class="container">
      <div class="reality__inner reveal">
        <p class="label label--muted">DIE REALITÄT</p>
        <h2 class="reality__claim">Du brauchst keine fünf Tage.<br>Du brauchst zwei gute.</h2>
        <p class="reality__body">Viele Väter scheitern nicht an fehlendem Wissen — sondern an unrealistischen Erwartungen. Zu viel Volumen, zu wenig Schlaf, ständig wechselnde Pläne. Fortschritt entsteht nicht durch möglichst viele Trainingstage.</p>
        <div class="reality__formula">
          <div class="reality__factor">
            <span class="reality__factor-icon">⚡</span>
            <span class="reality__factor-label">Trainingsreiz</span>
          </div>
          <span class="reality__op">+</span>
          <div class="reality__factor">
            <span class="reality__factor-icon">🔋</span>
            <span class="reality__factor-label">Regeneration</span>
          </div>
          <span class="reality__op">+</span>
          <div class="reality__factor">
            <span class="reality__factor-icon">📅</span>
            <span class="reality__factor-label">Konsistenz</span>
          </div>
          <span class="reality__op reality__op--approx">≈</span>
          <div class="reality__factor reality__factor--result">
            <span class="reality__factor-label">Fortschritt</span>
          </div>
        </div>
        <p class="reality__close">Zwei harte, ehrliche Ganzkörpereinheiten pro Woche. Kein Influencer-Lifestyle. Kein stundenlanges Pumpen. Nur das, was wirklich funktioniert — für Männer mit Verantwortung.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════ DIE PHILOSOPHIE -->
  <section class="section" id="philosophy">
    <div class="container">
      <div class="section__header">
        <p class="label label--accent">DIE PHILOSOPHIE</p>
        <h2 class="section__title">Warum genau<br>dieser Trainingsplan?</h2>
        <p class="section__lead">Dad Strong basiert auf wenigen, gut gestützten Prinzipien — nicht auf dem neuesten Trend.</p>
      </div>

      <div class="philosophy__layout">
        <div class="philosophy__cards">
          <article class="card reveal">
            <span class="card__num">01</span>
            <h3 class="card__title">Wenige Übungen</h3>
            <p class="card__body">Mehr Fokus. Weniger Chaos. Grundübungen trainieren viele Muskelgruppen gleichzeitig — maximaler Nutzen pro investierter Papa-Zeit.</p>
          </article>
          <article class="card reveal" style="--delay:.08s">
            <span class="card__num">02</span>
            <h3 class="card__title">Fokus auf Beine & hintere Kette</h3>
            <p class="card__body">Kraft. Stabilität. Energie für den Alltag. Deshalb liegt hier bewusst der Schwerpunkt — das zahlt sich auch auf dem Spielplatz aus.</p>
          </article>
          <article class="card reveal" style="--delay:.16s">
            <span class="card__num">03</span>
            <h3 class="card__title">Progression statt Zerstörung</h3>
            <p class="card__body">Wenige harte Arbeitssätze, klare Steigerung, messbare Entwicklung. Kein Muskelkater der dich am nächsten Tag lahmlegt.</p>
          </article>
          <article class="card reveal" style="--delay:.24s">
            <span class="card__num">04</span>
            <h3 class="card__title">Entwickelt für Väter</h3>
            <p class="card__body">Arbeit. Familie. Verpflichtungen. Dad Strong läuft in kurzen Einheiten, braucht wenig Nachdenken — und lässt sich trotzdem konsequent durchziehen.</p>
          </article>
        </div>

        <div class="philosophy__mockup reveal" style="--delay:.1s">
          <div class="iphone">
            <div class="iphone__dynamic-island" aria-hidden="true"></div>
            <div class="iphone__btn iphone__btn--action" aria-hidden="true"></div>
            <div class="iphone__btn iphone__btn--vol-up" aria-hidden="true"></div>
            <div class="iphone__btn iphone__btn--vol-down" aria-hidden="true"></div>
            <div class="iphone__btn iphone__btn--side" aria-hidden="true"></div>
            <div class="iphone__screen">
              <Image src={appHome} alt="Dad Strong iOS App – Übersicht Kraft-, Ausdauer- und Sprint-Streaks auf dem Home Screen" format="avif" loading="lazy" />
            </div>
          </div>
          <div class="mockup__label">
            <span class="label label--muted" style="margin:0">STARTSCREEN</span>
            <p class="mockup__caption">Dein Training. Sofort sichtbar.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════ DIE GESCHICHTE -->
  <section class="section about-section" id="story">
    <div class="container">
      <div class="about__layout">
        <div class="about__left">
          <p class="label label--muted">WARUM DAD STRONG?</p>
          <blockquote class="about__pull">
            "Viele Fitness-Inhalte vermitteln das Gefühl, dass ein fitter Körper das Zentrum des Lebens sein sollte."
          </blockquote>
          <p class="about__byline">— Christian Bachmann, Entwickler</p>
        </div>
        <div class="about__right reveal">
          <p>Mehr Disziplin. Mehr Härte. Mehr Optimierung. Mehr Motivation.</p>
          <p>Lange habe ich genau so gedacht. Ich habe Ergebnisse riesig gemacht — so, als würde ein bestimmter Körper irgendwann alles verändern.</p>

          <div class="about__rule"></div>

          <p>Aber irgendwann wurde mir etwas klar: Die meisten Menschen leben kein Leben, das sich um Training dreht.</p>
          <div class="about__list">
            <span>Arbeit</span><span>Kinder</span><span>Schlafmangel</span><span>Stress</span><span>Verantwortung</span>
          </div>
          <p>Und genau darin liegt die eigentliche Herausforderung. Nicht die einzelne Trainingseinheit. Sondern die Fähigkeit, trotz eines normalen, oft repetitiven Lebens langfristig dranzubleiben.</p>

          <div class="about__rule"></div>

          <p>Die Wahrheit ist: Fortschritt entsteht meistens nicht spektakulär. Er entsteht durch normale Tage, kleine Entscheidungen, Wiederholung und Konsequenz trotz Alltag.</p>

          <div class="about__rule"></div>

          <p>Denn am Ende interessiert sich kaum jemand so sehr für deinen Körper wie du selbst. Aber:</p>
          <div class="about__values">
            <span>Energie</span><span>Stabilität</span><span>Gesundheit</span><span>Selbstrespekt</span><span>Belastbarkeit</span>
          </div>
          <p class="about__conclusion">Dad Strong soll dabei helfen — nicht perfekt zu werden. Sondern langfristig stark zu bleiben.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════ DER PLAN -->
  <section class="section section--surface" id="plan">
    <div class="container">
      <div class="section__header">
        <p class="label label--accent">DER PLAN</p>
        <h2 class="section__title">Training A & B</h2>
        <p class="section__lead">Fest. Nicht konfigurierbar. Das ist das Produkt.</p>
      </div>

      <div class="training__grid">
        <div class="training__block reveal">
          <header class="training__header">
            <span class="training__tag">Training A</span>
          </header>
          <div class="training__exercises">
            <div class="exercise">
              <div class="exercise__name">Kniebeuge</div>
              <div class="exercise__why">Hoher Gesamtreiz · Beine · Rumpf · Kraftaufbau</div>
            </div>
            <div class="exercise">
              <div class="exercise__name">Bankdrücken</div>
              <div class="exercise__why">Oberkörperkraft · progressiv belastbar · effizient</div>
            </div>
            <div class="exercise">
              <div class="exercise__name">Rudern</div>
              <div class="exercise__why">Rücken · Ausgleich zum Drücken · Haltung</div>
            </div>
            <div class="exercise">
              <div class="exercise__name">Bulgarian Split Squat</div>
              <div class="exercise__why">Unilateral · Beine · Balance · Beweglichkeit</div>
            </div>
            <div class="exercise">
              <div class="exercise__name">Farmer Walk</div>
              <div class="exercise__why">Grip · Rumpf · Kondition · mentale Stärke</div>
            </div>
          </div>
        </div>

        <div class="training__block reveal" style="--delay:.15s">
          <header class="training__header">
            <span class="training__tag">Training B</span>
          </header>
          <div class="training__exercises">
            <div class="exercise">
              <div class="exercise__name">Kreuzheben</div>
              <div class="exercise__why">Hintere Kette · Rücken · maximale Last · Fundament</div>
            </div>
            <div class="exercise">
              <div class="exercise__name">Overhead Press</div>
              <div class="exercise__why">Schultern · Rumpf · Stabilität · echte Kraft</div>
            </div>
            <div class="exercise">
              <div class="exercise__name">Klimmzüge</div>
              <div class="exercise__why">Rückenbreite · relative Kraft · Körpergewicht</div>
            </div>
            <div class="exercise">
              <div class="exercise__name">Frontkniebeuge</div>
              <div class="exercise__why">Beinvorderseite · aufrechte Haltung · Mobilität</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Warum nicht veränderbar -->
      <div class="training__why reveal" style="--delay:.2s">
        <div class="training__why-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
        </div>
        <div>
          <p class="training__why-title">Warum kann ich den Plan nicht anpassen?</p>
          <p class="training__why-body">Weil Variation den Fortschritt hindert. Wer die Übungen ständig wechselt, trainiert nie lange genug an einer Bewegung um wirklich stark zu werden. Lineare Progression braucht Kontinuität — keine Abwechslung. Der Plan ist das Produkt.</p>
        </div>
      </div>

      <!-- Progression Demo -->
      <div class="progression reveal" style="--delay:.25s">
        <div class="progression__header">
          <p class="label label--muted">LINEARE PROGRESSION · BEISPIEL KNIEBEUGE</p>
        </div>
        <div class="progression__track">
          <div class="progression__weeks">
            <span>Woche 1</span>
            <span>Woche 4</span>
            <span>Woche 8</span>
            <span>Woche 12</span>
          </div>
          <div class="progression__bar">
            <div class="progression__fill" id="progFill"></div>
          </div>
          <div class="progression__weights">
            <span class="prog-w">60 kg</span>
            <span class="prog-w">72 kg</span>
            <span class="prog-w">85 kg</span>
            <span class="prog-w prog-w--accent">100 kg</span>
          </div>
        </div>
        <p class="progression__note">Nicht garantiert — aber realistisch.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════ MID-PAGE CTA STRIP -->
  <div class="midcta reveal">
    <div class="container">
      <div class="midcta__inner">
        <div class="midcta__line" aria-hidden="true"></div>
        <div class="midcta__content">
          <p class="midcta__heading">Du weißt genug.</p>
          <a href="#download" class="midcta__btn">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            Kostenlos laden
          </a>
        </div>
        <div class="midcta__line" aria-hidden="true"></div>
      </div>
    </div>
  </div>

  <!-- ════════════════════════════════════════════════ ZONE 2 -->
  <section class="section section--surface zone2-section" id="zone2">

    <!-- Background pulse decoration -->
    <div class="zone2__bg-pulse" aria-hidden="true">
      <svg viewBox="0 0 1200 160" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0 100 L120 100 L150 100 L170 30 L195 140 L215 55 L240 100 L360 100 L390 100 L410 20 L435 148 L455 42 L480 100 L600 100 L630 100 L650 14 L675 152 L695 38 L720 100 L840 100 L870 100 L890 22 L915 146 L935 46 L960 100 L1080 100 L1110 100 L1130 18 L1155 150 L1175 40 L1200 100"
          stroke="#ff8c1a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.12"/>
      </svg>
    </div>

    <div class="container">
      <div class="zone2__layout">

        <!-- Left: Text -->
        <div class="zone2__text reveal">
          <p class="label label--zone2">ZONE 2 & SPRINT</p>
          <h2 class="zone2__title">Kein weiteres<br>„Du musst mehr."</h2>
          <p class="zone2__lead">Zone 2 ist eher das Gegenteil. Eine lockere Cardio-Einheit, die den Kopf runterfährt, die Regeneration unterstützt — und dich wieder wie ein Mensch fühlen lässt.</p>

          <blockquote class="zone2__quote">
            30–45 Minuten aufs Bike. Netflix an. Kein Druck. Kein Vollgas.
            <cite>Ich nutze dafür selbst ein Yesoul Bike und schaue dabei einfach Netflix oder YouTube. Kein kompliziertes Setup. Einfach bewegen.</cite>
          </blockquote>

          <ul class="zone2__benefits">
            <li>Ausdauer aufbauen</li>
            <li>Regeneration verbessern</li>
            <li>Stress runterfahren</li>
            <li>Kalorien verbrennen</li>
            <li>Langfristig fitter werden — ohne den Körper zu zerstören</li>
          </ul>

          <div class="zone2__optional">
            <span class="zone2__optional-label">Das Beste daran</span>
            <p>Es ist optional. Dad Strong basiert nicht auf maximalem Aufwand, sondern auf einem System, das du trotz Arbeit, Kindern und Alltag langfristig durchziehen kannst.</p>
          </div>

          <div class="zone2__healthkit">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <span>Herzfrequenz via Apple Health — kein separates Gerät nötig.</span>
          </div>
        </div>

        <!-- Right: Mockup -->
        <div class="zone2__visual reveal" style="--delay:.12s">
          <Image
            src={appMockupZone2}
            alt="Dad Strong App – Zone 2 Cardio Tracking mit Herzfrequenz via Apple Health"
            format="avif"
            loading="lazy"
            class="zone2__mockup-img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════ SPRINT -->
  <section class="section sprint-section" id="sprint">

    <!-- Bars: section-level, span both columns -->
    <div class="sprint__bars reveal" aria-hidden="true">
      <!-- Block 1 -->
      <div class="sbar" style="--w:12%;--delay:.05s"></div>
      <div class="sbar" style="--w:14%;--delay:.1s"></div>
      <div class="sbar" style="--w:16%;--delay:.15s"></div>
      <div class="sbar sbar--mark" style="--w:19%;--delay:.2s"></div>
      <div class="sbar sbar--gap"></div>
      <!-- Block 2 -->
      <div class="sbar" style="--w:24%;--delay:.25s"></div>
      <div class="sbar" style="--w:27%;--delay:.3s"></div>
      <div class="sbar" style="--w:31%;--delay:.35s"></div>
      <div class="sbar sbar--mark" style="--w:35%;--delay:.4s"></div>
      <div class="sbar sbar--gap"></div>
      <!-- Block 3 -->
