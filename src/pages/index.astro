  .section { padding: clamp(80px, 12vw, 140px) 0; }
  .section--surface { background: #111111; }

  /* ─────────────────────────────── ATOMS */
  .label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .label--accent { color: #d4ff00; }
  .label--muted  { color: #888; }

  .section__header { margin-bottom: clamp(48px, 7vw, 88px); }
  .section__title {
    font-family: 'Bebas Neue', cursive;
    font-size: clamp(52px, 9vw, 100px);
    line-height: 0.95;
    letter-spacing: 0.025em;
    color: #fff;
    margin-bottom: 20px;
  }
  .section__lead { font-size: 17px; color: #aaaaaa; line-height: 1.65; max-width: 520px; }

  /* ─────────────────────────────── BUTTON */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #d4ff00;
    color: #000;
    font-family: 'Barlow', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 15px 28px;
    border-radius: 12px;
    transition: opacity .18s, transform .18s;
  }
  .btn-primary:hover { opacity: .85; transform: translateY(-1px); }
  .btn-primary--large { font-size: 15px; padding: 20px 44px; border-radius: 14px; }

  /* ─────────────────────────────── NAV */
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    padding: 18px 0;
    background: rgba(0,0,0,.82);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(255,255,255,.05);
  }
  .nav__inner {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 clamp(24px, 5vw, 72px);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav__logo { font-family: 'Bebas Neue', cursive; font-size: 21px; letter-spacing: .12em; color: #fff; }
  .nav__cta {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #d4ff00;
    text-decoration: none;
    border: 1px solid rgba(212,255,0,.35);
    padding: 8px 18px;
    border-radius: 8px;
    transition: background .18s, color .18s, border-color .18s;
  }
  .nav__cta:hover { background: #d4ff00; color: #000; border-color: #d4ff00; }

  /* ─────────────────────────────── HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 64px;
    position: relative;
    overflow: hidden;
  }
  .hero .container { position: relative; z-index: 1; }
  .hero__label { animation: fadeUp .55s .05s both; }
  .hero__title {
    font-family: 'Bebas Neue', cursive;
    font-size: clamp(96px, 20vw, 260px);
    line-height: .88;
    letter-spacing: .01em;
    color: #fff;
    margin-bottom: clamp(28px, 4vw, 52px);
    animation: fadeUp .65s .15s both;
  }
  .hero__sub { max-width: 480px; animation: fadeUp .65s .3s both; }
  .hero__tagline {
    font-family: 'Bebas Neue', cursive;
    font-size: clamp(28px, 4.5vw, 52px);
    color: #d4ff00;
    letter-spacing: .06em;
    line-height: 1.05;
    margin-bottom: 18px;
  }
  .hero__body { font-size: 16px; color: #aaaaaa; line-height: 1.7; margin-bottom: 36px; }
  .hero__divider {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(212,255,0,.25), transparent);
  }

  /* ─────────────────────────────── HERO BARS */
  .hero__bars {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 75%;
    display: flex;
    align-items: flex-end;
    gap: 6px;
    padding: 0 clamp(24px, 5vw, 72px);
    pointer-events: none;
    z-index: 0;
    -webkit-mask-image: linear-gradient(to top, black 70%, transparent 100%);
    mask-image: linear-gradient(to top, black 70%, transparent 100%);
  }
  .hbar {
    flex: 1;
    height: var(--h, 40%);
    position: relative;
    border-radius: 3px 3px 0 0;
    background: linear-gradient(to top, rgba(212,255,0,.04) 0%, rgba(212,255,0,.10) 100%);
    transform: scaleY(0);
    transform-origin: bottom center;
    animation: barRise .9s var(--delay, 0s) cubic-bezier(.23,1,.32,1) both;
  }
  .hbar--gap { flex: 0.4; background: transparent; animation: none; transform: none; }
  .hbar--mark::after {
    content: attr(data-label);
    position: absolute;
    top: -22px;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    color: rgba(212,255,0,.35);
    white-space: nowrap;
    letter-spacing: .05em;
    opacity: 0;
    animation: labelFade .5s calc(var(--delay, 0s) + .5s) ease both;
  }
  .hbar--peak {
    background: linear-gradient(to top, rgba(212,255,0,.08) 0%, rgba(212,255,0,.30) 100%);
    box-shadow: 0 0 24px rgba(212,255,0,.12);
  }
  .hbar--peak::after { color: #d4ff00; font-size: 11px; }

  /* ─────────────────────────────── KENNST DU DAS */
  .pain__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 56px;
  }
  .pain {
    display: flex;
    gap: 14px;
    padding: 20px 22px;
    background: #000;
    border: 1px solid rgba(255,255,255,.06);
    border-radius: 14px;
    transition: border-color .2s;
  }
  .pain:hover { border-color: rgba(255,255,255,.12); }
  .pain__num {
    font-family: 'DM Mono', monospace;
    font-size: 18px;
    color: rgba(255,255,255,.15);
    flex-shrink: 0;
    line-height: 1.4;
  }
  .pain__text { font-size: 15px; color: #bbb; line-height: 1.6; }

  .pain__answer {
    border-top: 1px solid rgba(255,255,255,.06);
    padding-top: 48px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .pain__answer-text {
    font-family: 'Bebas Neue', cursive;
    font-size: clamp(32px, 5vw, 56px);
    letter-spacing: .04em;
    color: #d4ff00;
  }
  .pain__answer-sub { font-size: 16px; color: #aaaaaa; max-width: 540px; line-height: 1.65; }

  /* ─────────────────────────────── PHILOSOPHY LAYOUT */
  .philosophy__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 7vw, 96px);
    align-items: center;
  }
  .philosophy__cards { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

  /* ─────────────────────────────── CARDS */
  .card {
    background: #111;
    border: 1px solid rgba(255,255,255,.06);
    border-radius: 16px;
    padding: clamp(20px, 2.5vw, 28px);
    position: relative;
    overflow: hidden;
    transition: border-color .25s, transform .25s;
  }
  .card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: #d4ff00;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .35s cubic-bezier(.23,1,.32,1);
  }
  .card:hover::after { transform: scaleX(1); }
  .card:hover { border-color: rgba(212,255,0,.12); transform: translateY(-2px); }
  .card__num {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: .18em;
    color: #d4ff00;
    display: block;
    margin-bottom: 12px;
  }
  .card__title { font-size: 17px; font-weight: 700; color: #fff; margin-bottom: 8px; line-height: 1.2; }
  .card__body { font-size: 13px; color: #aaaaaa; line-height: 1.65; }

  /* ─────────────────────────────── iPHONE MOCKUP */
  .philosophy__mockup { display: flex; flex-direction: column; align-items: center; gap: 24px; }
  .philosophy__mockup-img { width: 280px; height: auto; filter: drop-shadow(0 32px 64px rgba(0,0,0,.5)); }
  .iphone {
    position: relative;
    width: clamp(220px, 28vw, 320px);
    aspect-ratio: 390 / 844;
    background: #0a0a0a;
    border-radius: clamp(40px, 6vw, 54px);
    border: 2px solid rgba(255,255,255,.1);
    box-shadow:
      0 0 0 1px rgba(255,255,255,.06),
      inset 0 0 0 1px rgba(255,255,255,.04),
      0 32px 80px rgba(0,0,0,.8),
      0 0 60px rgba(212,255,0,.06);
    overflow: visible;
  }
  .iphone__dynamic-island {
    position: absolute;
    top: 3.5%; left: 50%;
    transform: translateX(-50%);
    width: 30%; height: 4%;
    background: #000;
    border-radius: 20px;
    z-index: 10;
    box-shadow: 0 0 0 1px rgba(255,255,255,.06);
  }
  .iphone__btn { position: absolute; background: #1e1e1e; border-radius: 2px; }
  .iphone__btn--action   { left: -3px; top: 8%;  width: 3px; height: 5%; }
  .iphone__btn--vol-up   { left: -3px; top: 16%; width: 3px; height: 7%; }
  .iphone__btn--vol-down { left: -3px; top: 25%; width: 3px; height: 7%; }
  .iphone__btn--side     { right: -3px; top: 16%; width: 3px; height: 10%; }
  .iphone__screen { position: absolute; inset: 0; border-radius: inherit; overflow: hidden; }
  .iphone__screen img { width: 100%; height: 100%; object-fit: cover; object-position: top center; display: block; }
  .mockup__label { text-align: center; }
  .mockup__caption { font-size: 14px; color: #aaaaaa; margin-top: 6px; }

  /* ─────────────────────────────── REALITY BRIDGE */
  .reality-section { background: #000; border-top: 1px solid rgba(255,255,255,.06); border-bottom: 1px solid rgba(255,255,255,.06); }
  .reality__inner { max-width: 760px; }
  .reality__claim {
    font-family: 'Bebas Neue', cursive;
    font-size: clamp(38px, 6vw, 64px);
    letter-spacing: .03em;
    color: #fff;
    line-height: 1.05;
    margin: 14px 0 20px;
  }
  .reality__body {
    font-size: 16px;
    color: #aaaaaa;
    line-height: 1.7;
    max-width: 600px;
    margin-bottom: 40px;
  }
  .reality__formula {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    padding: 28px 32px;
    background: #0d0d0d;
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 16px;
    margin-bottom: 32px;
  }
  .reality__factor {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 14px 20px;
    background: rgba(255,255,255,.04);
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,.06);
    min-width: 110px;
  }
  .reality__factor--result {
    background: rgba(212,255,0,.06);
    border-color: rgba(212,255,0,.2);
  }
  .reality__factor--result .reality__factor-label { color: #d4ff00; }
  .reality__factor-icon { font-size: 20px; line-height: 1; }
  .reality__factor-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #888;
  }
  .reality__op {
    font-family: 'DM Mono', monospace;
    font-size: 22px;
    color: #444;
    padding: 0 4px;
  }
  .reality__op--approx { color: #d4ff00; font-size: 28px; }
  .reality__close {
    font-size: 16px;
    color: #aaaaaa;
    line-height: 1.7;
    max-width: 600px;
  }
  @media (max-width: 600px) {
    .reality__formula { padding: 20px 16px; gap: 8px; }
    .reality__factor { min-width: 80px; padding: 10px 12px; }
    .reality__factor-icon { display: none; }
  }

  /* ─────────────────────────────── PHONES SHOWCASE */
  .phones-showcase {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: 24px;
    margin: 0 auto 80px;
    max-width: 640px;
  }
  .phones-showcase__phone {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    flex: 1;
  }
  .phones-showcase__phone--raised {
    transform: translateY(-32px);
  }
  .phones-showcase__phone img {
    width: 100%;
    max-width: 280px;
    height: auto;
    border-radius: 4px;
    filter: drop-shadow(0 32px 64px rgba(0,0,0,.6));
  }
  .phones-showcase__label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #777;
  }
  @media (max-width: 500px) {
    .phones-showcase { gap: 12px; }
    .phones-showcase__phone--raised { transform: translateY(-16px); }
  }

  /* ─────────────────────────────── ABOUT / GESCHICHTE */
  .about-section { background: #0a0a0a; }
  .about__layout {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(40px, 8vw, 120px);
    align-items: start;
  }
  .about__left { position: sticky; top: 100px; }
  .about__pull {
    font-family: 'Bebas Neue', cursive;
    font-size: clamp(32px, 4.5vw, 52px);
    line-height: 1.1;
    letter-spacing: .03em;
    color: #fff;
    border: none;
    padding: 0;
    font-style: normal;
    margin: 0 0 16px;
  }
  .about__byline { font-size: 13px; color: #777; font-style: italic; }

  .about__right { display: flex; flex-direction: column; gap: 18px; }
  .about__right p {
    font-size: 16px;
    color: #888;
    line-height: 1.75;
  }
  .about__rule {
    height: 1px;
    background: rgba(255,255,255,.06);
    margin: 6px 0;
  }
  .about__conclusion {
    font-size: 17px !important;
    color: #ccc !important;
    font-weight: 600;
    padding: 20px 24px;
    border-left: 2px solid #d4ff00;
    background: rgba(212,255,0,.04);
    border-radius: 0 10px 10px 0;
  }

  /* ─────────────────────────────── TRAINING PLAN */
  .training__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
  .training__block {
    background: #000;
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 16px;
    overflow: hidden;
  }
  .training__header {
    padding: 18px 28px;
    border-bottom: 1px solid rgba(255,255,255,.07);
    background: rgba(212,255,0,.04);
  }
  .training__tag { font-family: 'Bebas Neue', cursive; font-size: 20px; letter-spacing: .1em; color: #d4ff00; }
  .training__exercises { padding: 4px 0; }
  .exercise {
    padding: 14px 28px;
    border-bottom: 1px solid rgba(255,255,255,.04);
    transition: background .18s;
  }
  .exercise:last-child { border-bottom: none; }
  .exercise:hover { background: rgba(212,255,0,.03); }
  .exercise__name { font-size: 15px; font-weight: 600; color: #fff; margin-bottom: 3px; }
  .exercise__why { font-size: 12px; color: #888; letter-spacing: .02em; }

  /* Warum nicht veränderbar callout */
  .training__why {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 20px 24px;
    background: rgba(212,255,0,.04);
    border: 1px solid rgba(212,255,0,.1);
    border-radius: 12px;
    margin-bottom: 20px;
  }
  .training__why-icon { color: #d4ff00; flex-shrink: 0; margin-top: 2px; }
  .training__why-title {
    font-size: 14px;
    font-weight: 700;
    color: #d4ff00;
    margin-bottom: 6px;
    letter-spacing: .02em;
  }
  .training__why-body { font-size: 14px; color: #aaaaaa; line-height: 1.65; }

  /* Progression */
  .progression {
    background: #000;
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 16px;
    padding: clamp(24px, 3vw, 40px);
  }
  .progression__header { margin-bottom: 20px; }
  .progression__weeks {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #777;
    margin-bottom: 8px;
  }
  .progression__bar {
    height: 5px;
    background: rgba(255,255,255,.07);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 8px;
  }
  .progression__fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(to right, rgba(212,255,0,.35), #d4ff00);
    border-radius: 3px;
    transition: width 1.6s cubic-bezier(.23,1,.32,1);
  }
  .progression__fill.active { width: 100%; }
  .progression__weights { display: flex; justify-content: space-between; margin-bottom: 12px; }
  .prog-w { font-family: 'DM Mono', monospace; font-size: 13px; color: #888; }
  .prog-w--accent { color: #d4ff00; font-weight: 500; }
  .progression__note { font-size: 12px; color: rgba(255,255,255,.18); }

  /* ─────────────────────────────── FEATURES */
  .features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.06);
    border-radius: 16px;
    overflow: hidden;
  }
  .feature--accent { grid-column: span 2; background: rgba(212,255,0,.03); border-top: 1px solid rgba(212,255,0,.08); }
  .feature {
    padding: clamp(24px, 3vw, 36px);
    background: #000;
    display: flex;
    flex-direction: column;
    transition: background .18s;
  }
  .feature:hover { background: #111; }
  .feature--accent:hover { background: rgba(212,255,0,.05); }
  .feature__top {
    display: flex;
    gap: 18px;
    align-items: flex-start;
    margin-bottom: 20px;
  }
  .feature__icon {
    width: 42px; height: 42px;
    border-radius: 10px;
    background: rgba(212,255,0,.07);
    display: flex; align-items: center; justify-content: center;
    color: #d4ff00;
    flex-shrink: 0;
  }
  .feature__icon--accent { background: rgba(212,255,0,.14); }
  .feature__title { font-size: 15px; font-weight: 700; color: #fff; margin-bottom: 5px; }
  .feature__body { font-size: 13px; color: #aaaaaa; line-height: 1.6; }
  .streak__demo { display: flex; gap: 6px; margin-top: 16px; }
  .streak__day {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    width: 36px; height: 36px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
  }
  /* About lists */
  .about__list, .about__values {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 4px 0 16px;
  }
  .about__list span, .about__values span {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,.1);
    color: rgba(255,255,255,.5);
  }
  .about__values span {
    border-color: rgba(212,255,0,.2);
    color: #d4ff00;
    background: rgba(212,255,0,.05);
  }

  /* Progression mock */
  .prog-mock {
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(255,255,255,.06);
    border-radius: 10px;
    overflow: hidden;
  }
  .prog-mock__header {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 12px;
    padding: 8px 14px;
    background: rgba(255,255,255,.04);
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .12em;
    color: #777;
    text-transform: uppercase;
  }
  .prog-mock__row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 12px;
    padding: 9px 14px;
    border-top: 1px solid rgba(255,255,255,.04);
    font-size: 13px;
    color: rgba(255,255,255,.5);
    font-family: 'DM Mono', monospace;
    transition: background .15s;
  }
  .prog-mock__row:hover { background: rgba(255,255,255,.03); }
  .prog-mock__up { color: #d4ff00; font-weight: 500; }

  /* Body check-in mock */
  .feature--body { grid-column: span 2; }
  .body-mock { margin-top: 4px; display: flex; gap: 16px; align-items: flex-end; }
  .body-mock__photos { display: flex; gap: 10px; flex: 1; }
  .body-mock__photo {
    flex: 1;
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(255,255,255,.06);
    border-radius: 10px;
    padding: 12px 8px 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .body-mock__photo svg { width: 100%; max-width: 48px; height: auto; }
  .body-mock__photo span {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .12em;
    color: #777;
  }
  .body-mock__stats {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 120px;
  }
  .body-mock__stat {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 7px 12px;
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(255,255,255,.05);
    border-radius: 8px;
  }
  .body-mock__stat-label { font-size: 12px; color: #888; }
  .body-mock__stat-val { font-family: 'DM Mono', monospace; font-size: 12px; color: #fff; font-weight: 500; }

  /* Widget tile — span 2, horizontal layout */
  .feature--widget {
    grid-column: span 2;
    flex-direction: row;
    align-items: center;
    gap: 40px;
  }
  .feature--widget .feature__widget-text { flex: 1; min-width: 0; }
  .feature--widget .feature__top { margin-bottom: 0; }
  .widget-mockup-img {
    flex-shrink: 0;
    width: 240px;
