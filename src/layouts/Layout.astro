---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Dad Strong – Krafttraining App für Väter mit wenig Zeit',
  description = 'Die Krafttraining-App für vielbeschäftigte Väter. 2 Einheiten pro Woche, linearer Fortschritt, kein tägliches Training. Für Väter mit Job, Kindern und dem Ziel, stark zu sein und gut auszusehen. Kostenlos für iPhone.',
  canonical = 'https://dadstrong.app/',
} = Astro.props;

const ogImage = 'https://dadstrong.app/screenshots/dadstrong-app-home-screen.png';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Dad Strong" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Mobile -->
    <meta name="theme-color" content="#000000" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black" />

    <!-- Structured Data: SoftwareApplication -->
    <script type="application/ld+json" is:inline>
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Dad Strong",
        "url": "https://dadstrong.app/",
        "operatingSystem": "iOS 17+",
        "applicationCategory": "HealthApplication",
        "description": "Krafttraining App für Väter mit wenig Zeit. Fixer Plan, 2 Einheiten pro Woche, lineare Progression. Für vielbeschäftigte Väter die stark sein und gut aussehen wollen.",
        "keywords": "Krafttraining Väter, Fitness App Väter, Training App Papas, Krafttraining wenig Zeit, Väter Fitness",
        "inLanguage": "de",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "EUR"
        },
        "author": {
          "@type": "Person",
          "name": "Christian Bachmann",
          "url": "https://dadstrong.app/"
        },
        "publisher": {
          "@type": "Person",
          "name": "Christian Bachmann"
        }
      })}
    </script>

    <!-- Structured Data: FAQPage -->
    <script type="application/ld+json" is:inline>
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Kostet die Dad Strong App Geld?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja — einmaliger Kauf. Kein Abo, keine monatlichen Kosten, keine Premium-Version. Du bezahlst einmal und hast die App für immer."
            }
          },
          {
            "@type": "Question",
            "name": "Gibt es ein Abo oder versteckte Kosten bei Dad Strong?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nein. Keine Abonnements, keine In-App-Käufe, keine Werbung. Das war von Anfang an so geplant — weil du als Vater ohnehin genug Fixkosten hast."
            }
          },
          {
            "@type": "Question",
            "name": "Kann ich meinen Trainingsplan in Dad Strong anpassen?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nein — und das ist Absicht. Variation hindert Fortschritt. Wer die Übungen ständig wechselt, baut keine echte Stärke auf. Der Plan ist das Produkt. Das ist der Punkt."
            }
          },
          {
            "@type": "Question",
            "name": "Ist Dad Strong wissenschaftlich fundiert?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dad Strong basiert auf progressiver Überladung und Grundübungen — die Basis jedes seriösen Krafttrainingsprogramms. Keine Geheimformel, kein Trend. Nur das, was nachweislich funktioniert."
            }
          },
          {
            "@type": "Question",
            "name": "Brauche ich ein Gym oder bestimmte Geräte für Dad Strong?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ein Rack, eine Langhantel, Gewichtsscheiben. Das war's. Kein Kabelzug, kein Gerät, kein Smith Machine. Was du brauchst, gibt es in jedem normalen Gym."
            }
          },
          {
            "@type": "Question",
            "name": "Was passiert wenn ich mal ein Training bei Dad Strong verpasse?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dann machst du das nächste Training. Fertig. Dad Strong hat keinen künstlichen Streak-Druck. Leben passiert — das System ist dafür gebaut."
            }
          },
          {
            "@type": "Question",
            "name": "Bekomme ich mit Dad Strong einen Sixpack?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ein Sixpack entsteht durch ein Kaloriendefizit — nicht durch Bauchübungen. Was das Training leistet: du baust die großen Muskelgruppen auf — Beine, Rücken, Brust. Mehr Muskelmasse bedeutet einen höheren Grundumsatz. Das unterstützt ein Defizit langfristig. Sichtbare Bauchmuskeln kommen über die Küche, nicht über das Gym."
            }
          },
          {
            "@type": "Question",
            "name": "Funktioniert Dad Strong auch in einer Aufbauphase (Bulk)?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja. Das Training ist unabhängig davon was du isst. Lineare Progression funktioniert sowohl im Kalorienüberschuss als auch im Defizit. Der Plan passt zu beiden Zielen."
            }
          },
          {
            "@type": "Question",
            "name": "Kann ich bei Dad Strong Übungen ergänzen?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Der Sinn des Plans ist Progression, Standardisierung und Kontrolle. Teste erst mal 12 Wochen das vorgegebene Programm. Du wirst überrascht sein, wie weit dich zwei solide Einheiten bringen."
            }
          },
          {
            "@type": "Question",
            "name": "Wie funktioniert das Kaloriendefizit mit Dad Strong?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Empfehlung: Kalorien tracken mit einer einfachen App wie Yazio. Für die 12-Wochen-Challenge ein aggressives Defizit wählen und die Priorität auf das Defizit setzen — außer den zwei Pflichttrainings pro Woche. Jeden Morgen wiegen, um den Trend zu sehen. Das funktioniert auch neben Vollzeitjob und Kindern."
            }
          },
          {
            "@type": "Question",
            "name": "Ich trainiere und esse im Defizit — warum bewegt sich die Waage nicht?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Die wichtigere Frage: Verlierst du Bauchumfang? Wenn ja, passiert genau das was passieren soll. Der Grund: Muskeln sind dichter als Fett. Wer gleichzeitig Fett abbaut und Muskeln aufbaut, kann dieselbe Körpermasse auf der Waage haben — sieht aber komplett anders aus. Das nennt sich Body Recomposition, tritt besonders stark beim Trainingseinstieg auf. Dazu kommt: Muskelgewebe speichert Glykogen, das Wasser bindet — das kann 1–2 kg auf der Waage erklären. Maßband schlägt Waage."
            }
          },
          {
            "@type": "Question",
            "name": "Wie messe ich meinen Bauchumfang richtig?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Drei Regeln: 1. Immer dieselbe Stelle — knapp unter dem Bauchnabel, wo Bauch und Hüfte am meisten rausstehen. 2. Band flach auflegen, nicht einschneiden — weder locker noch eingeklemmt. 3. Morgens, nüchtern, vor dem ersten Kaffee — dann ist der Bauch am leersten und die Werte vergleichbar."
            }
          }
        ]
      })}
    </script>

    <!-- Structured Data: WebSite (Sitelinks Search) -->
    <script type="application/ld+json" is:inline>
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Dad Strong",
        "url": "https://dadstrong.app/"
      })}
    </script>

    <!-- Fonts (self-hosted – no external requests) -->
    <style>
      @font-face {
        font-family: 'Bebas Neue';
        src: url('/fonts/BebasNeue-Regular.ttf') format('truetype');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Barlow';
        src: url('/fonts/Barlow-400.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Barlow';
        src: url('/fonts/Barlow-600.woff2') format('woff2');
        font-weight: 600;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Barlow';
        src: url('/fonts/Barlow-700.woff2') format('woff2');
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'DM Mono';
        src: url('/fonts/DMMono-400.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'DM Mono';
        src: url('/fonts/DMMono-500.woff2') format('woff2');
        font-weight: 500;
        font-style: normal;
        font-display: swap;
      }
    </style>
    <link rel="preload" href="/fonts/BebasNeue-Regular.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/Barlow-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Barlow-700.woff2" as="font" type="font/woff2" crossorigin />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  </head>
  <body>
    <slot />
  </body>
</html>
