---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Dad Strong – Krafttraining App für Väter',
  description = 'Krafttraining App für Väter 30–45. Fixer Plan, 2 Einheiten pro Woche, lineare Progression. Kein Chaos, keine Ausreden — echter Fortschritt. Kostenlos für iPhone.',
  canonical = 'https://dadstrong.app/',
} = Astro.props;

const ogImage = 'https://dadstrong.app/screenshots/dadstrong-app-home-screen.png';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Dad Strong" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Mobile -->
    <meta name="theme-color" content="#000000" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black" />

    <!-- Structured Data: SoftwareApplication -->
    <script type="application/ld+json" is:inline>
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Dad Strong",
        "operatingSystem": "iOS",
        "applicationCategory": "HealthApplication",
        "description": "Krafttraining App für Väter. Fixer Plan, 2 Einheiten pro Woche, lineare Progression.",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "EUR"
        },
        "author": {
          "@type": "Person",
          "name": "Christian Bachmann"
        }
      })}
    </script>

    <!-- Fonts (self-hosted – no external requests) -->
    <style>
      @font-face {
        font-family: 'Bebas Neue';
        src: url('/fonts/BebasNeue-Regular.ttf') format('truetype');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Barlow';
        src: url('/fonts/Barlow-400.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Barlow';
        src: url('/fonts/Barlow-600.woff2') format('woff2');
        font-weight: 600;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Barlow';
        src: url('/fonts/Barlow-700.woff2') format('woff2');
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'DM Mono';
        src: url('/fonts/DMMono-400.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'DM Mono';
        src: url('/fonts/DMMono-500.woff2') format('woff2');
        font-weight: 500;
        font-style: normal;
        font-display: swap;
      }
    </style>
    <link rel="preload" href="/fonts/BebasNeue-Regular.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/Barlow-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Barlow-700.woff2" as="font" type="font/woff2" crossorigin />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  </head>
  <body>
    <slot />
  </body>
</html>
