---
import LangSwitcher from './LangSwitcher.astro';
import CalorieCalculator from './CalorieCalculator.astro';
import { calcPage, TESTFLIGHT_URL } from '../i18n/calculator';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const p = calcPage[lang];
const homeHref = lang === 'de' ? '/' : '/en/';
const tf = TESTFLIGHT_URL;
---

<nav class="calc-nav">
  <a href={homeHref} class="calc-nav__brand">DAD STRONG</a>
  <div class="calc-nav__right">
    <LangSwitcher lang={lang} page="calculator" />
    <a href={homeHref} class="calc-nav__back">{p.navBack}</a>
  </div>
</nav>

<main class="calc-page">
  <header class="calc-hero">
    <p class="calc-eyebrow">{lang === 'de' ? 'KOSTENLOSER RECHNER' : 'FREE CALCULATOR'}</p>
    <h1 class="calc-h1">{p.h1}</h1>
    <p class="calc-lead">{p.lead}</p>
  </header>

  <div class="calc-widget">
    <CalorieCalculator lang={lang} />
  </div>

  <aside class="calc-distinct">
    <p class="calc-distinct__title">{p.distinctTitle}</p>
    <p class="calc-distinct__body">{p.distinctBody}</p>
  </aside>

  <article class="calc-article">
    {p.sections.map((section) => (
      <section class="calc-section">
        <h2 class="calc-h2">{section.h2}</h2>
        {section.paragraphs.map((para) => (<p class="calc-p">{para}</p>))}
      </section>
    ))}
  </article>

  <section class="calc-faq-section">
    <h2 class="calc-h2">{p.faqTitle}</h2>
    <div class="calc-faq__list">
      {p.faq.map((item) => (
        <details class="calc-faq">
          <summary class="calc-faq__q">{item.q}</summary>
          {item.a.map((ans) => (<p class="calc-faq__a">{ans}</p>))}
        </details>
      ))}
    </div>
  </section>

  <section class="calc-cta">
    <h2 class="calc-cta__title">{p.ctaTitle}</h2>
    <p class="calc-cta__body">{p.ctaBody}</p>
    <a href={tf} class="calc-cta__btn" target="_blank" rel="noopener">
      <svg width="24" height="24" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect width="40" height="40" rx="9" fill="#147EFB"/>
        <rect x="18.5" y="5" width="3" height="26" rx="1.5" fill="white"/>
        <path d="M20 14 L5 22 L5 26 L20 20 L35 26 L35 22 Z" fill="white"/>
        <path d="M20 22 L9 27 L9 31 L20 27 L31 31 L31 27 Z" fill="white"/>
      </svg>
      {p.ctaBtn}
    </a>
  </section>
</main>

<footer class="calc-footer">
  <span class="calc-footer__brand">DAD STRONG</span>
  <nav class="calc-footer__links">
    <a href={homeHref}>{lang === 'de' ? 'Startseite' : 'Home'}</a>
    <a href={lang === 'de' ? '/privacy/' : '/en/privacy/'}>{lang === 'de' ? 'Datenschutz & Impressum' : 'Privacy & Imprint'}</a>
    <a href="mailto:info@dadstrong.app">{lang === 'de' ? 'Kontakt' : 'Contact'}</a>
  </nav>
</footer>

<style>
  .calc-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    padding: 16px 24px;
    background: rgba(0,0,0,.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,.06);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .calc-nav__brand {
    font-family: 'Bebas Neue', cursive;
    font-size: 18px;
    letter-spacing: .12em;
    color: #fff;
    text-decoration: none;
  }
  .calc-nav__right { display: flex; align-items: center; gap: 18px; }
  .calc-nav__back { font-size: 13px; color: #888; text-decoration: none; transition: color .18s; }
  .calc-nav__back:hover { color: #fff; }

  .calc-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 120px 24px 80px;
  }

  .calc-hero { margin-bottom: 40px; }
  .calc-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: #d4ff00;
    margin: 0 0 16px;
  }
  .calc-h1 {
    font-family: 'Bebas Neue', cursive;
    font-size: clamp(44px, 8vw, 76px);
    line-height: .95;
    letter-spacing: .02em;
    color: #fff;
    margin: 0 0 20px;
  }
  .calc-lead {
    font-size: 17px;
    color: #aaaaaa;
    line-height: 1.65;
    max-width: 560px;
    margin: 0;
  }

  .calc-widget { margin-bottom: 24px; }

  .calc-distinct {
    background: rgba(212,255,0,.04);
    border: 1px solid rgba(212,255,0,.12);
    border-radius: 14px;
    padding: 22px 26px;
    margin-bottom: 64px;
  }
  .calc-distinct__title {
    font-size: 15px;
    font-weight: 700;
    color: #d4ff00;
    margin: 0 0 8px;
  }
  .calc-distinct__body {
    font-size: 14px;
    color: #aaaaaa;
    line-height: 1.7;
    margin: 0;
  }

  .calc-section { margin-bottom: 48px; }
  .calc-h2 {
    font-family: 'Bebas Neue', cursive;
    font-size: clamp(28px, 4.5vw, 40px);
    letter-spacing: .03em;
    color: #fff;
    line-height: 1.05;
    margin: 0 0 18px;
  }
  .calc-p {
    font-size: 16px;
    color: #aaaaaa;
    line-height: 1.75;
    margin: 0 0 14px;
    max-width: 660px;
  }

  .calc-faq-section { margin: 64px 0; }
  .calc-faq__list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: rgba(255,255,255,.06);
    border-radius: 16px;
    overflow: hidden;
  }
  .calc-faq { background: #000; transition: background .18s; }
  .calc-faq[open] { background: #0d0d0d; }
  .calc-faq__q {
    list-style: none;
    padding: 20px 24px;
    font-size: 16px;
    font-weight: 600;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    user-select: none;
    transition: color .18s;
  }
  .calc-faq__q:hover { color: #d4ff00; }
  .calc-faq__q::-webkit-details-marker { display: none; }
  .calc-faq__q::after {
    content: '+';
    font-family: 'DM Mono', monospace;
    font-size: 20px;
    color: #777;
    flex-shrink: 0;
    transition: transform .25s, color .18s;
  }
  .calc-faq[open] .calc-faq__q::after { transform: rotate(45deg); color: #d4ff00; }
  .calc-faq__a {
    padding: 0 24px 20px;
    font-size: 15px;
    color: #aaaaaa;
    line-height: 1.7;
    margin: 0;
  }

  .calc-cta {
    text-align: center;
    background: #111;
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 20px;
    padding: 48px 32px;
    margin-top: 24px;
  }
  .calc-cta__title {
    font-family: 'Bebas Neue', cursive;
    font-size: clamp(32px, 5vw, 52px);
    letter-spacing: .03em;
    color: #fff;
    line-height: 1;
    margin: 0 0 16px;
  }
  .calc-cta__body {
    font-size: 16px;
    color: #aaaaaa;
    line-height: 1.65;
    max-width: 520px;
    margin: 0 auto 28px;
  }
  .calc-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #000;
    background: #d4ff00;
    text-decoration: none;
    padding: 16px 32px;
    border-radius: 14px;
    transition: opacity .18s, transform .18s;
  }
  .calc-cta__btn:hover { opacity: .85; transform: translateY(-1px); }

  .calc-footer {
    max-width: 760px;
    margin: 0 auto;
    padding: 32px 24px;
    border-top: 1px solid rgba(255,255,255,.05);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }
  .calc-footer__brand {
    font-family: 'Bebas Neue', cursive;
    font-size: 17px;
    letter-spacing: .12em;
    color: rgba(255,255,255,.25);
  }
  .calc-footer__links { display: flex; gap: 24px; flex-wrap: wrap; }
  .calc-footer__links a {
    font-size: 13px;
    color: rgba(255,255,255,.28);
    text-decoration: none;
    transition: color .18s;
  }
  .calc-footer__links a:hover { color: #fff; }

  @media (max-width: 600px) {
    .calc-page { padding-top: 96px; }
  }
</style>
