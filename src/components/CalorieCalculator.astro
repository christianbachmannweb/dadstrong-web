---
import { calcUI } from '../i18n/calculator';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const ui = calcUI[lang];

// Only the data the client script needs (keeps the inlined payload small).
const calcData = {
  numberLocale: ui.numberLocale,
  kcal: ui.kcal,
  noteTemplate: ui.noteTemplate,
  warnLow: ui.warnLow,
  warnHigh: ui.warnHigh,
  modes: ui.modes.map((m) => ({
    deficit: m.deficit,
    weeklyLoss: m.weeklyLoss,
    totalLoss: m.totalLoss,
  })),
};
---

<div class="calc" id="calorie-calc">
  <p class="calc__label">{ui.label}</p>
  <p class="calc__heading">{ui.heading}</p>

  <div class="calc__form">
    <div class="calc__row">
      <div class="calc__field">
        <label class="calc__field-label" for="calc-age">{ui.age}</label>
        <div class="calc__input-wrap">
          <input class="calc__input" type="number" id="calc-age" min="18" max="80" value="38" inputmode="numeric" />
          <span class="calc__unit">{ui.ageUnit}</span>
        </div>
      </div>
      <div class="calc__field">
        <label class="calc__field-label" for="calc-weight">{ui.weight}</label>
        <div class="calc__input-wrap">
          <input class="calc__input" type="number" id="calc-weight" min="50" max="250" value="85" inputmode="numeric" />
          <span class="calc__unit">{ui.weightUnit}</span>
        </div>
      </div>
      <div class="calc__field">
        <label class="calc__field-label" for="calc-height">{ui.height}</label>
        <div class="calc__input-wrap">
          <input class="calc__input" type="number" id="calc-height" min="150" max="220" value="178" inputmode="numeric" />
          <span class="calc__unit">{ui.heightUnit}</span>
        </div>
      </div>
    </div>

    <div class="calc__modes">
      {ui.modes.map((mode, i) => (
        <button class:list={['calc__mode-btn', { 'calc__mode-btn--active': i === 0 }]} type="button">
          <span class="calc__mode-name">{mode.name}</span>
          <span class="calc__mode-deficit">{mode.deficitLabel}</span>
          <span class="calc__mode-desc">{mode.desc}</span>
        </button>
      ))}
    </div>
  </div>

  <div class="calc__result" id="calc-result" aria-live="polite">
    <div class="calc__result-row">
      <div class="calc__result-block">
        <span class="calc__result-label">{ui.resBmr}</span>
        <span class="calc__result-val" id="res-bmr">—</span>
      </div>
      <div class="calc__result-block">
        <span class="calc__result-label">{ui.resTdee}</span>
        <span class="calc__result-val" id="res-tdee">—</span>
      </div>
      <div class="calc__result-block calc__result-block--accent">
        <span class="calc__result-label">{ui.resTarget}</span>
        <span class="calc__result-val" id="res-target">—</span>
      </div>
    </div>
    <p class="calc__note" id="res-note"></p>
    <p class="calc__warning" id="res-warning" style="display:none"></p>
  </div>
</div>

<style>
  .calc {
    background: #111;
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 20px;
    padding: 40px;
  }
  .calc__label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #d4ff00;
    margin: 0 0 10px;
  }
  .calc__heading {
    font-family: 'Bebas Neue', cursive;
    font-size: clamp(24px, 3vw, 36px);
    letter-spacing: .05em;
    color: #fff;
    margin: 0 0 32px;
  }
  .calc__row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }
  .calc__field { display: flex; flex-direction: column; gap: 8px; }
  .calc__field-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #888;
  }
  .calc__input-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 10px;
    padding: 12px 14px;
  }
  .calc__input {
    background: transparent;
    border: none;
    outline: none;
    color: #fff;
    font-family: 'DM Mono', monospace;
    font-size: 20px;
    font-weight: 500;
    width: 100%;
    min-width: 0;
    -moz-appearance: textfield;
  }
  .calc__input::-webkit-outer-spin-button,
  .calc__input::-webkit-inner-spin-button { -webkit-appearance: none; }
  .calc__unit {
    font-size: 12px;
    font-weight: 600;
    color: #777;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Three-tier mode selector */
  .calc__modes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 32px;
  }
  .calc__mode-btn {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 12px;
    padding: 16px 16px;
    cursor: pointer;
    text-align: left;
    transition: border-color .18s, background .18s;
  }
  .calc__mode-btn--active {
    border-color: rgba(212,255,0,.4);
    background: rgba(212,255,0,.04);
  }
  .calc__mode-name {
    display: block;
    font-size: 14px;
    font-weight: 700;
    color: #aaa;
    letter-spacing: .02em;
  }
  .calc__mode-btn--active .calc__mode-name { color: #d4ff00; }
  .calc__mode-deficit {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    color: #777;
    margin-bottom: 4px;
  }
  .calc__mode-btn--active .calc__mode-deficit { color: #bbb; }
  .calc__mode-desc {
    display: block;
    font-size: 11px;
    color: #777;
    line-height: 1.5;
    font-weight: 500;
  }
  .calc__mode-btn--active .calc__mode-desc { color: #999; }

  /* Results */
  .calc__result {
    border-top: 1px solid rgba(255,255,255,.06);
    padding-top: 28px;
  }
  .calc__result-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 16px;
  }
  .calc__result-block {
    display: flex;
    flex-direction: column;
    gap: 6px;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,.06);
    border-radius: 12px;
    padding: 16px 18px;
  }
  .calc__result-block--accent {
    border-color: rgba(212,255,0,.18);
    background: rgba(212,255,0,.03);
  }
  .calc__result-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #888;
  }
  .calc__result-val {
    font-family: 'DM Mono', monospace;
    font-size: 22px;
    font-weight: 500;
    color: #fff;
  }
  .calc__result-block--accent .calc__result-val { color: #d4ff00; }
  .calc__note {
    font-size: 13px;
    color: #888;
    margin: 0 0 8px;
    line-height: 1.6;
  }
  .calc__warning {
    font-size: 13px;
    color: #f22626;
    margin: 0;
    line-height: 1.6;
    padding: 12px 16px;
    background: rgba(242,38,38,.06);
    border: 1px solid rgba(242,38,38,.2);
    border-radius: 8px;
  }

  @media (max-width: 700px) {
    .calc { padding: 24px 18px; }
    .calc__row { gap: 10px; }
    .calc__input { font-size: 18px; }
    .calc__modes { grid-template-columns: 1fr; gap: 8px; }
    .calc__mode-btn { flex-direction: row; align-items: center; gap: 12px; padding: 14px 16px; }
    .calc__mode-name { min-width: 72px; }
    .calc__mode-deficit { margin-bottom: 0; }
    .calc__mode-desc { display: none; }
    .calc__result-row { grid-template-columns: 1fr; gap: 10px; }
  }
  @media (max-width: 420px) {
    .calc__row { grid-template-columns: 1fr; }
  }
</style>

<script define:vars={{ calcData }}>
  (function () {
    var ageEl = document.getElementById('calc-age');
    var weightEl = document.getElementById('calc-weight');
    var heightEl = document.getElementById('calc-height');
    var buttons = Array.prototype.slice.call(document.querySelectorAll('.calc__mode-btn'));
    var resBmr = document.getElementById('res-bmr');
    var resTdee = document.getElementById('res-tdee');
    var resTarget = document.getElementById('res-target');
    var resNote = document.getElementById('res-note');
    var resWarning = document.getElementById('res-warning');
    if (!ageEl || !weightEl || !heightEl || !buttons.length) return;

    // PAL 1.55: desk job + 2× strength + 1× zone2/sprint per week
    var PAL = 1.55;
    var modes = calcData.modes;
    var activeMode = 0;

    function fmt(n) {
      return n.toLocaleString(calcData.numberLocale) + ' ' + calcData.kcal;
    }

    function calculate() {
      var age = parseInt(ageEl.value, 10) || 38;
      var weight = parseFloat(weightEl.value) || 85;
      var height = parseFloat(heightEl.value) || 178;

      // Mifflin-St Jeor (2005) — best validated RMR formula (male offset +5)
      var bmr = Math.round(10 * weight + 6.25 * height - 5 * age + 5);
      var tdee = Math.round(bmr * PAL);

      var mode = modes[activeMode];
      var target = tdee - mode.deficit;

      resBmr.textContent = fmt(bmr);
      resTdee.textContent = fmt(tdee);
      resTarget.textContent = fmt(target);

      resNote.textContent = calcData.noteTemplate
        .replace('{total}', mode.totalLoss)
        .replace('{weekly}', mode.weeklyLoss);

      var deficit = tdee - target;
      if (target < 1500) {
        resWarning.style.display = 'block';
        resWarning.textContent = calcData.warnLow.replace(
          '{target}',
          target.toLocaleString(calcData.numberLocale)
        );
      } else if (deficit > 800) {
        resWarning.style.display = 'block';
        resWarning.textContent = calcData.warnHigh.replace(
          '{deficit}',
          deficit.toLocaleString(calcData.numberLocale)
        );
      } else {
        resWarning.style.display = 'none';
      }
    }

    function setMode(i) {
      activeMode = i;
      buttons.forEach(function (btn, idx) {
        btn.classList.toggle('calc__mode-btn--active', idx === i);
      });
      calculate();
    }

    buttons.forEach(function (btn, i) {
      btn.addEventListener('click', function () { setMode(i); });
    });
    [ageEl, weightEl, heightEl].forEach(function (el) {
      el.addEventListener('input', calculate);
    });

    calculate();
  })();
</script>
